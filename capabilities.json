{
  "dataRoles": [
    { "name": "groupName",    "kind": "GroupingOrMeasure", "displayName": "Grupo" },
    { "name": "taskName",     "kind": "GroupingOrMeasure", "displayName": "Nome da Tarefa" },
    { "name": "taskId",       "kind": "GroupingOrMeasure", "displayName": "ID da Tarefa" },
    { "name": "wbs",          "kind": "GroupingOrMeasure", "displayName": "WBS" },
    { "name": "outlineLevel", "kind": "Measure",           "displayName": "Outline Level" },
    { "name": "plannedStart", "kind": "Measure",           "displayName": "Início Planejado" },
    { "name": "plannedEnd",   "kind": "Measure",           "displayName": "Fim Planejado" },
    { "name": "baselineStart","kind": "Measure",           "displayName": "Início Baseline" },
    { "name": "baselineEnd",  "kind": "Measure",           "displayName": "Fim Baseline" },
    { "name": "progress",     "kind": "Measure",           "displayName": "% Conclusão" },
    { "name": "dependencies", "kind": "Measure",           "displayName": "Dependências" },
    { "name": "isMilestone",  "kind": "GroupingOrMeasure", "displayName": "Marco (True/False)" }
  ],
  "dataViewMappings": [
    {
      "table": {
        "rows": {
          "select": [
            { "for": { "in": "groupName" } },
            { "for": { "in": "taskName" } },
            { "for": { "in": "taskId" } },
            { "for": { "in": "wbs" } },
            { "for": { "in": "outlineLevel" } },
            { "for": { "in": "plannedStart" } },
            { "for": { "in": "plannedEnd" } },
            { "for": { "in": "baselineStart" } },
            { "for": { "in": "baselineEnd" } },
            { "for": { "in": "progress" } },
            { "for": { "in": "dependencies" } },
            { "for": { "in": "isMilestone" } }
          ],
          "dataReductionAlgorithm": { "window": { "count": 2000 } }
        }
      }
    }
  ],
  "objects": {
    "ganttColors": {
      "properties": {
        "plannedBarColor":        { "type": { "fill": { "solid": { "color": true } } } },
        "summaryBarColor":        { "type": { "fill": { "solid": { "color": true } } } },
        "baselineBarColor":       { "type": { "fill": { "solid": { "color": true } } } },
        "progressColor":          { "type": { "fill": { "solid": { "color": true } } } },
        "todayLineColor":         { "type": { "fill": { "solid": { "color": true } } } },
        "milestoneColor":         { "type": { "fill": { "solid": { "color": true } } } },
        "milestoneBaselineColor": { "type": { "fill": { "solid": { "color": true } } } },
        "dependencyLineColor":   { "type": { "fill": { "solid": { "color": true } } } }
      }
    },
    "ganttLayout": {
      "properties": {
        "rowHeight":        { "type": { "numeric": true } },
        "wbsColumnWidth":   { "type": { "numeric": true } },
        "taskLabelWidth":   { "type": { "numeric": true } },
        "showDependencies": { "type": { "bool": true } },
        "showToday":        { "type": { "bool": true } },
        "showBaseline":     { "type": { "bool": true } },
        "showStatusLabels": { "type": { "bool": true } },
        "showStatusBar":    { "type": { "bool": true } },
        "showWbs":          { "type": { "bool": true } }
      }
    }
  },
  "privileges": [],
  "supportsHighlight": true,
  "supportsMultiVisualSelection": true,
  "supportsSynchronizingFilterState": true,
  "sorting": { "default": {} }
}